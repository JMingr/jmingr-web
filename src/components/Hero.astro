---
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'

/**
 * Hero Component
 *
 * @description A component that displays a hero section with a title, description, and image
 */
interface Props {
  /**
   * The source URL for the image
   */
  src?: string
}

const { src = '/me-500.jpg' }: Props = Astro.props
---

<section class="hero pt-48" id="home">
  <div class="container">
    <div class="grid grid-cols-1 items-center gap-24 lg:grid-cols-2">
      <div class="flex flex-col items-center gap-8 md:items-start">
        <div class="flex flex-col gap-1">
          <h1 class="text-3xl font-extrabold lg:text-5xl">
            <span class="text-gradient">Jose Miguel</span> Mingorance Rejón
          </h1>
          <p class="text-xl font-medium text-neutral-600 lg:text-2xl dark:text-neutral-400">Senior Android Developer</p>
          <p class="mt-4 max-w-2xl text-lg text-neutral-600 dark:text-neutral-400">
            Desarrollador <strong class="font-semibold text-neutral-900 dark:text-white">Android nativo</strong> especializado
            en crear aplicaciones estables y eficientes. Disfruto construyendo <strong
              class="font-semibold text-neutral-900 dark:text-white">interfaces limpias</strong
            > y, en mi tiempo libre, trasteando con <strong class="font-semibold text-neutral-900 dark:text-white"
              >automatizaciones y servidores locales</strong
            >.
          </p>
        </div>
        <div class="flex flex-col gap-3 min-[500px]:flex-row">
          <div class="mt-4 flex flex-wrap gap-4">
            <a
              href="https://www.linkedin.com/in/jose-miguel-mingorance/"
              target="_blank"
              rel="noopener noreferrer"
              title="Perfil de LinkedIn"
              class="group flex h-14 w-14 items-center justify-center rounded-full border border-neutral-200 bg-white text-neutral-600 !no-underline shadow-sm transition-all hover:scale-110 hover:border-blue-500 hover:text-blue-600 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400 dark:hover:border-blue-500 dark:hover:text-blue-400"
            >
              <Icon name="lucide:linkedin" class="h-6 w-6" />
            </a>

            <a
              href="mailto:dev@jmingr.es"
              rel="noopener noreferrer"
              title="Enviar Email"
              class="group flex h-14 w-14 items-center justify-center rounded-full border border-neutral-200 bg-white text-neutral-600 !no-underline shadow-sm transition-all hover:scale-110 hover:border-teal-500 hover:text-teal-600 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400 dark:hover:border-teal-500 dark:hover:text-teal-400"
            >
              <Icon name="lucide:mail" class="h-6 w-6" />
            </a>
          </div>
        </div>
      </div>
      <Image
        class="border-primary/10 mx-auto hidden aspect-square rounded-full border-4 shadow-2xl lg:block"
        src={src}
        alt="Jose Miguel"
        decoding="async"
        width={450}
        height={450}
        loading="eager"
      />
    </div>
  </div>
</section>

<style lang="scss">
  h1 {
    text-wrap: unset;
  }

  .text-gradient {
    background: linear-gradient(
      315deg,
      light-dark(var(--color-primary-300), var(--color-secondary-100)) 25%,
      light-dark(var(--color-secondary-300), var(--color-primary-200))
    );
    background-clip: border-box;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
