---
import { Icon } from 'astro-icon/components'

/**
 * About me Component
 *
 * @description A component that displays About me from Astro Content Collections
 */
interface Props {
  /**
   * Additional classes to apply to the section
   */
  class?: string
  /**
   * The title for the section
   * @default "Sobre mí"
   */
  title?: string
}
---

<section id="about-me" class="mt-24 mb-32 bg-neutral dark:bg-neutral-900/50 pt-24 pb-16 rounded-3xl">
  <div class="container">
    <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
      <div>
        <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-8">Un poco sobre mí</h2>
        <div class="mb-8 space-y-4 text-lg text-neutral-600 dark:text-neutral-400">
          <p>
            Programando desde 2012 como Desarrollador Android, he tenido la suerte de vivir la evolución
            completa del ecosistema nativo. Actualmente formo parte del equipo de <strong>Sngular</strong>, trabajando
            en proyectos a gran escala para gigantes como <strong>Inditex (Zara)</strong>.
          </p>
          <p>
            Anteriormente, he dejado mi huella en aplicaciones como BBVA, Acciona, y he ejercido como Team Leader en
            Leroy Merlin, asegurando la calidad del código y la arquitectura del proyecto. Disfruto construyendo
            productos estables que usan millones de personas cada día.
          </p>
        </div>

        <h3 class="mb-4 text-sm font-bold tracking-wider text-neutral-500 uppercase">Stack y Aptitudes</h3>
        <div class="flex flex-wrap gap-2">
          <span
            class="rounded-lg border border-blue-200 bg-blue-100 px-3 py-1.5 text-sm font-semibold text-blue-800 dark:border-blue-800/50 dark:bg-blue-900/30 dark:text-blue-300"
            >Kotlin</span
          >
          <span
            class="rounded-lg border border-neutral-300 bg-neutral-200 px-3 py-1.5 text-sm font-semibold text-neutral-800 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-200"
            >Java</span
          >
          <span
            class="rounded-lg border border-neutral-300 bg-neutral-200 px-3 py-1.5 text-sm font-semibold text-neutral-800 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-200"
            >Jetpack Compose</span
          >
          <span
            class="rounded-lg border border-neutral-300 bg-neutral-200 px-3 py-1.5 text-sm font-semibold text-neutral-800 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-200"
            >Clean Architecture</span
          >
          <span
            class="rounded-lg border border-neutral-300 bg-neutral-200 px-3 py-1.5 text-sm font-semibold text-neutral-800 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-200"
            >SOLID</span
          >
          <span
            class="rounded-lg border border-neutral-300 bg-neutral-200 px-3 py-1.5 text-sm font-semibold text-neutral-800 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-200"
            >Coroutines & Flow</span
          >
          <span
            class="rounded-lg border border-neutral-300 bg-neutral-200 px-3 py-1.5 text-sm font-semibold text-neutral-800 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-200"
            >Dagger / Hilt / Koin</span
          >
          <span
            class="rounded-lg border border-neutral-300 bg-neutral-200 px-3 py-1.5 text-sm font-semibold text-neutral-800 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-200"
            >MVVM / MVI</span
          >
          <span
            class="rounded-lg border border-neutral-300 bg-neutral-200 px-3 py-1.5 text-sm font-semibold text-neutral-800 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-200"
            >CI/CD</span
          >
        </div>
      </div>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div
          class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-700 dark:bg-neutral-800"
        >
          <Icon name="lucide:trending-up" class="mb-4 h-8 w-8 text-emerald-500" />
          <h4 class="mb-2 font-bold">Gran Escala</h4>
          <p class="text-sm text-neutral-500 dark:text-neutral-400">
            Acostumbrado a trabajar en apps críticas y de alto tráfico utilizadas por millones de usuarios.
          </p>
        </div>

        <div
          class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-700 dark:bg-neutral-800"
        >
          <Icon name="lucide:users" class="mb-4 h-8 w-8 text-blue-500" />
          <h4 class="mb-2 font-bold">Team Lead & Calidad</h4>
          <p class="text-sm text-neutral-500 dark:text-neutral-400">
            Experiencia liderando equipos y asegurando la escalabilidad del proyecto.
          </p>
        </div>

        <div
          class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-700 dark:bg-neutral-800"
        >
          <Icon name="lucide:smartphone" class="mb-4 h-8 w-8 text-purple-500" />
          <h4 class="mb-2 font-bold">Android Nativo</h4>
          <p class="text-sm text-neutral-500 dark:text-neutral-400">
            Usuario y desarrollador fiel al ecosistema. Pixel en el bolsillo y reloj en la muñeca.
          </p>
        </div>

        <div
          class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-700 dark:bg-neutral-800"
        >
          <Icon name="lucide:server" class="mb-4 h-8 w-8 text-orange-500" />
          <h4 class="mb-2 font-bold">Homelab & Cacharreo</h4>
          <p class="text-sm text-neutral-500 dark:text-neutral-400">
            Aficionado al self-hosting, a levantar Dockers y a automatizar luces en casa que no necesitaban ser
            automatizadas.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
